{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@icons/*": ["icons/*"],
      "@components/*": ["components/*"],
      "@layouts/*": ["layouts/*"],
      "@config/*": ["config/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"]
    }
  }
}
