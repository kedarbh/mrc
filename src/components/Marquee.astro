---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const partners = await getCollection("partners");

// Duplicate the partners array so the infinite scroll animation is seamless
const scrollingPartners = [...partners, ...partners];
---

<style>
  .marquee-container {
    overflow: hidden;
    position: relative;
    width: 100%;
    /* Create a subtle fade out effect on the left and right edges */
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .marquee-content {
    display: flex;
    width: fit-content;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-content:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Translate halfway since we doubled the array content */
      transform: translateX(-50%);
    }
  }
</style>

<div class="pt-20 bg-white ">
  <div class="wrapper text-center mb-8">
    <p class="text-sm font-bold text-gray-500 uppercase tracking-widest">Trusted By Global Partners</p>
  </div>
  
  <div class="marquee-container max-w-6xl mx-auto px-4">
    <div class="marquee-content flex items-center gap-16 md:gap-24">
      {scrollingPartners.map((partner) => (
        <a 
          href={partner.data.website || "/partners"} 
          target={partner.data.website ? "_blank" : "_self"}
          rel="noopener noreferrer"
          class="flex-shrink-0 w-32 md:w-40 h-20 relative flex items-center justify-center grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300"
          title={partner.data.name}
        >
          {partner.data.logo ? (
            <Image 
              src={partner.data.logo} 
              alt={partner.data.name} 
              class="max-w-full max-h-full object-contain"
            />
          ) : (
            <span class="font-bold text-gray-800 text-lg md:text-xl truncate">{partner.data.name.split(' ')[0]}</span>
          )}
        </a>
      ))}
    </div>
  </div>
</div>
