---
import {Icon} from 'astro-icon/components'
import { Image } from 'astro:assets';
import featuredImage from '@assets/images/about_featured.png';
import SectionTitle from '@components/ui/SectionTitle.astro';
---

<div class="wrapper section ">
    <SectionTitle subtitle="Who We Are" class="mb-10 lg:mb-12">
        MRC Nepal: Together Building a <span class="text-secondary">Sustainable</span> Future
    </SectionTitle>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative">
            <div class="absolute inset-0 bg-primary/10 rounded-2xl transform translate-x-4 translate-y-4 -z-10"></div>
            <Image src={featuredImage} alt="happy peoples with banner against TB" class="rounded-2xl shadow-xl w-full object-cover h-[500px]" />
        </div>
        <div class="flex flex-col h-full justify-center">
            <p class="text-gray-600 text-lg leading-relaxed mb-8">
                MRC Nepal is a non-profit organization dedicated to fostering sustainable community development by reducing poverty through inclusive, participatory approaches. Guided by its vision of self-reliant, empowered societies, MRC Nepal integrates local resources and knowledge with innovative strategies to address critical challenges. Its mission focuses on improving livelihoods, promoting environmental sustainability, enhancing health and education, and advocating for human rights, ensuring equitable growth and resilience across Nepal's diverse communities.
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="p-2 bg-primary/10 rounded-lg">
                            <Icon name="vision" class="h-6 w-6 text-primary" />
                        </div>
                        <h2 class="font-bold text-xl text-gray-900">Vision</h2>
                    </div>
                    <p class="text-sm text-gray-600 leading-relaxed">Socially and economically sustainable communities built on equity, peace, and the dignity and prosperity of all.</p>
                </div>
                
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="p-2 bg-secondary/10 rounded-lg">
                            <Icon name="mission" class="h-6 w-6 text-secondary" />
                        </div>
                        <h2 class="font-bold text-xl text-gray-900">Mission</h2>
                    </div>
                    <p class="text-sm text-gray-600 leading-relaxed">Building sustainable and self-reliant societies in Nepal through community-driven initiatives.</p>
                </div>
            </div>
            
            <div class="mt-2">
                <a href="/about" class="btn-primary">Learn More About Us</a>
            </div>
        </div>
    </div>

    
    
</div>