---
import { Icon } from "astro-icon/components";
---

<section class="bg-green-900 text-white py-20 relative overflow-hidden">
    <!-- Decorative background element -->
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-secondary/10 blur-3xl"></div>
    
    <div class="wrapper relative z-10">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
            <div class="lg:w-3/5 text-center lg:text-left">
                <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-white/20 text-white text-sm font-bold uppercase tracking-wider mb-4">Get Involved</span>
                <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">Be a <span class="text-secondary">Change-Maker!</span></h2>
                <p class="text-lg text-white/80 mb-8 leading-relaxed max-w-2xl mx-auto lg:mx-0">
                    Your time and effort can make a real difference. Join our community of volunteers and create meaningful impact for the causes you care about!
                </p>
                <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
                  <a href="/volunteer" class="btn-primary w-full sm:w-auto">Volunteer Now &rarr;</a>
                  <a href="/careers" class="px-6 py-3 rounded-full border border-white/30 text-white font-medium hover:bg-white/10 transition-colors w-full sm:w-auto text-center">Explore Opportunities</a>
                </div>
            </div>
            
            <div class="lg:w-2/5 flex justify-center">
                <div class="bg-white/10 p-8 rounded-full backdrop-blur-sm border border-white/20 shadow-2xl">
                    <svg
                        class="h-48 w-48 text-white/90 drop-shadow-md"
                        fill="currentColor"
                        viewBox="0 0 106 106"
                    >
                        <path d="M52.68 0A53 53 0 001.12 63.87l3.07-1.64a5.83 5.83 0 016.42.62l8-4.29a21 21 0 0115.71-1.67l16.98 4.83a7 7 0 011.37 12.93 6.93 6.93 0 01-5 .6l-13.11-3.36a2.35 2.35 0 011.17-4.56L48.8 70.7a2.31 2.31 0 001.2-4.46l-16.93-4.83a16.31 16.31 0 00-12.21 1.3l-7.64 4.07L19.76 79a17 17 0 0114.05-.53l8.5 3.53a12.4 12.4 0 0010.51-.54l21.67-11.58a2.55 2.55 0 00-2.4-4.51l-8 4.3a2.35 2.35 0 11-2.21-4.15l8-4.3A7.26 7.26 0 0176.71 74L55 85.59a17 17 0 01-14.49.74L32 82.87a12.32 12.32 0 00-10.44.51 5.82 5.82 0 01-3.05 5.76l-2.15 1.15a2.4 2.4 0 01-.8.25A53 53 0 1052.68 0zm20.79 46.36L57.82 62.21 42 46.55a11.13 11.13 0 1115.63-15.84 11.13 11.13 0 1115.84 15.65z" />
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>