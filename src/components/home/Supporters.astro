---
const donorList = ['UNDP/GEF/SGP-UNOPS','WHO-Stop TB Partnership/CFCS','Tear Fund Uk', 'Stromme Foundation', 'OPEC/OFID','USAID/WWF-Hariyo Ban', 'USAID/DAI-Paani Project', 'Practical Action Nepal', 'GIZ/STPP', 'ABC Nepal', 'Plan International Nepal']
---

<div class="wrapper section">
    <div class="lg:text-center mb-12 max-w-2xl mx-auto">
        <p class="subtitle mx-auto justify-center flex items-center mb-4">Our Donors</p>
        <h2 class="title">Partners in <span>Building</span> Better Futures!</h2>
    </div>
    
    <div class="grid gap-6 grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 mb-12">
        {
            donorList.map((donor)=> (
                <div class="bg-white border border-gray-100 rounded-xl p-6 flex items-center justify-center text-center shadow-sm hover:shadow-md hover:border-primary hover:-translate-y-1 transition-all duration-300 min-h-[100px] cursor-default group">
                    <p class="text-sm font-semibold text-gray-600 group-hover:text-primary transition-colors">{donor}</p>
                </div>
            ))
        }
    </div>
    
    <div class="flex justify-center">
        <a href="#" class="btn-outlined">View All Supporters &rarr;</a>
    </div>
</div>