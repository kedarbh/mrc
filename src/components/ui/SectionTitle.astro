---
interface Props {
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { subtitle, align = 'left', class: className = '' } = Astro.props;

// Determine alignment classes
const wrapperClass = align === 'center' ? 'mx-auto text-center items-center' : 'text-left items-start';
const subtitleWrapperClass = align === 'center' ? 'mx-auto justify-center flex' : '';
---

<div class={`mb-12 max-w-2xl flex flex-col ${wrapperClass} ${className}`}>
  {subtitle && (
    <div class={subtitleWrapperClass}>
      <span class="inline-block py-1 px-3 rounded-full bg-primary/10 text-primary border border-primary/20 font-bold text-xs uppercase tracking-wider mb-4">
        {subtitle}
      </span>
    </div>
  )}
  <div class="w-full">
    <h2 class="font-extrabold text-3xl md:text-4xl leading-tight text-gray-900 mb-4 text-balance">
      <slot />
    </h2>
    {Astro.slots.has('description') && (
      <div class="text-lg leading-relaxed text-gray-600 font-medium">
        <slot name="description" />
      </div>
    )}
  </div>
</div>
