---
import 'swiper/css';
import 'swiper/css/pagination';
import 'swiper/css/effect-fade';

import sliderData from '@config/slider.json';
---

<div class="swiper hero-swiper w-full h-[85vh] relative group">
    <div class="swiper-wrapper">
        {sliderData.map((slide) => (
            <div class="swiper-slide overflow-hidden relative">
                <div class="absolute inset-0 bg-cover bg-center slide-bg transition-transform duration-[10000ms] ease-out scale-110" style={`background-image: url('${slide.image}');`}></div>
                <div class="absolute inset-0 bg-gradient-to-r from-green-950/90 via-green-900/60 to-transparent"></div>
                
                <div class="absolute inset-0 flex items-center">
                    <div class="wrapper w-full">
                        <div class="max-w-3xl slide-content opacity-0 translate-y-8 transition-all duration-1000 delay-300">
                            <span class={`inline-block py-1.5 px-4 rounded-full border text-sm font-bold uppercase tracking-widest mb-6 backdrop-blur-sm ${slide.badgeTheme}`}>
                                {slide.badgeText}
                            </span>
                            <h2 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white leading-tight mb-6 drop-shadow-lg">
                                {slide.title}
                            </h2>
                            <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl leading-relaxed drop-shadow-md">
                                {slide.description}
                            </p>
                            <div class="flex flex-wrap gap-4">
                                {slide.buttons.map(btn => (
                                    <a 
                                      href={btn.link} 
                                      class={btn.type === 'primary' 
                                            ? "btn-primary text-lg px-8 py-4" 
                                            : "px-8 py-4 rounded-full border-2 border-white/50 text-white font-bold hover:bg-white hover:text-green-900 transition-colors backdrop-blur-sm"}
                                    >
                                        {btn.text}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        ))}
    </div>
    
    <!-- Custom Pagination -->
    <div class="swiper-pagination !bottom-8 relative z-50"></div>
</div>

<style>
    /* Swiper Active State Animations */
    .swiper-slide-active .slide-bg {
        transform: scale(1);
    }
    
    .swiper-slide-active .slide-content {
        opacity: 1;
        transform: translateY(0);
    }

    /* Override Swiper Pagination Bullets to look premium */
    :global(.swiper-pagination-bullet) {
        width: 12px;
        height: 12px;
        background-color: rgba(255, 255, 255, 0.5);
        opacity: 1;
        transition: all 0.3s ease;
        border-radius: 6px;
    }
    
    :global(.swiper-pagination-bullet-active) {
        background-color: #F59E0B; /* Secondary color */
        width: 32px;
        background-color: #F59E0B !important;
    }
</style>

<script>
    import Swiper from 'swiper';
    import { Autoplay, Pagination, EffectFade } from 'swiper/modules';

    const swiper = new Swiper(".hero-swiper", {
        modules: [Pagination, EffectFade, Autoplay],
        effect: "fade",
        fadeEffect: {           
            crossFade: true
        }, 
        speed: 1500, /* Smooth slow fade between slides */
        loop: true,
        autoplay: {
            delay: 6000,
            disableOnInteraction: false,
        },
        pagination: {
            el: '.swiper-pagination',
            clickable: true,
        },
    });
</script>