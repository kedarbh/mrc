---
import { Image } from 'astro:assets';

import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"stories">;
}

const { story } = Astro.props;

const { title, publishedDate, coverImage, description } = story.data;
const month = publishedDate.toLocaleString('en-US', {month: 'long'});
const day = publishedDate.toLocaleString('en-US', {day:"numeric"});

---

<div class="bg-white rounded-lg shadow-lg overflow-hidden">
    <div class="relative">
        <Image src={coverImage} alt="Hathani packing vegetables from her field" class="h-64 object-cover"/>
        <div
        class="absolute top-2 left-2 bg-primary/80 text-white text-center text-sm font-bold px-3 py-1 rounded-tl-lg"
      >
        <p class="title">{day}</p>
        <p class="text-xs">{month}</p>
      </div>
    </div>
    <div class="p-4">
      <!-- <span
        class="bg-red-200 text-red-800 text-xs font-semibold px-2 py-1 rounded"
        >WATER</span
      > -->
      <h3 class="mt-2 text-lg font-bold text-gray-800">
        {title}
      </h3>
      <!-- <p class="text-sm text-gray-600 mt-2">
        Contrary to popular belief, Lorem Ipsum is not simply...
      </p> -->
    </div>
  </div>