---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import programsData from "../../config/programs.json";

export async function getStaticPaths() {
  return programsData.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
}

const { program } = Astro.props;
---

<Layout 
  title={`${program.title} | MRC Nepal Programs`}
  description={program.overview.substring(0, 155) + "..."}
>
  <!-- Page Header -->
  <section class="relative bg-green-900 text-white py-32 overflow-hidden">
    <div class="absolute inset-0 bg-primary/20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
    <div class="wrapper relative z-10 text-center max-w-4xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-secondary/20 text-secondary border border-secondary/30 font-medium text-sm mb-6 uppercase tracking-wider">
        Thematic Area
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        {program.title}
      </h1>
    </div>
  </section>

  <!-- Content Section -->
  <section class="section wrapper py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        
       <!-- Main Content -->
       <div class="lg:col-span-2">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Overview</h2>
            <p class="text-lg text-gray-700 leading-relaxed mb-10">
                {program.overview}
            </p>
            
            <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Key Activities
            </h3>
            <ul class="space-y-4">
                {program.activities.map((activity: string) => (
                    <li class="bg-gray-50 p-4 rounded-lg border border-gray-100 flex items-start gap-4">
                        <div class="mt-1">
                            <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </div>
                        <span class="text-gray-700 font-medium">{activity}</span>
                    </li>
                ))}
            </ul>
       </div>
       
       <!-- Sidebar -->
       <div>
            <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 shadow-sm sticky top-32">
                 <h4 class="text-lg font-bold text-gray-900 mb-6 pb-4 border-b border-gray-200">Other Programs</h4>
                 <ul class="space-y-3">
                     {programsData.filter(p => p.slug !== program.slug).map(p => (
                         <li>
                             <a href={`/programs/${p.slug}`} class="flex items-center gap-3 text-gray-600 hover:text-primary transition-colors group py-2">
                                 <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                 </svg>
                                 <span class="font-medium text-sm">{p.title}</span>
                             </a>
                         </li>
                     ))}
                 </ul>
                 
                 <div class="mt-8 pt-8 border-t border-gray-200 text-center">
                     <p class="text-sm text-gray-600 mb-4">Want to support these initiatives?</p>
                     <a href="/volunteer" class="btn-primary w-full shadow-lg shadow-primary/20 text-sm py-3 justify-center">Join as a Volunteer</a>
                 </div>
            </div>
       </div>
       
    </div>
  </section>
</Layout>
