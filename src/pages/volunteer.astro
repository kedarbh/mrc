---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <!-- Page Header -->
  <section class="relative bg-green-900 text-white py-32 overflow-hidden">
    <div class="absolute inset-0 bg-secondary/20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
    <div class="wrapper relative z-10 text-center max-w-4xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-secondary/20 text-secondary border border-secondary/30 font-medium text-sm mb-6 uppercase tracking-wider">
        Join Our Cause
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Be a <span class="text-secondary">Volunteer</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed italic">
        "The best way to find yourself is to lose yourself in the service of others."
      </p>
    </div>
  </section>

  <!-- Volunteer Info & Form -->
  <section class="section wrapper py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <!-- Information -->
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Make a Greater Impact</h2>
        
        <div class="prose prose-lg text-gray-600 mb-10 text-justify">
          <p>
            MRC Nepal works closely with rural communities in the field of sustainable livelihood. Volunteers at MRC Nepal work in the communities and programs where their unique skills can have the greatest impact. 
          </p>
          <p>
            As a volunteer, you will not only create a lasting impact on the lives of marginalized communities but also enhance your own skills and make lifelong friends when you return home.
          </p>
        </div>

        <div class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-lg mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-2">Current Openings</h3>
            <p class="text-gray-700">
                Currently, there are no open roles. However, if you are passionate to help, please apply through the form. We will get in touch with you when the best matching opportunities arise. 
            </p>
            <p class="mt-4 text-gray-700">
                 You can also email your application directly to: 
                 <a href="mailto:volunteer@mrcnepal.org.np" class="text-primary font-bold hover:underline inline-flex items-center gap-2 mt-2">
                    <Icon name="email" class="w-5 h-5" />
                    volunteer@mrcnepal.org.np
                 </a>
            </p>
        </div>
      </div>

      <!-- Application Form -->
      <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/5 rounded-full blur-2xl -mr-10 -mt-10"></div>
        
        <h2 class="text-3xl font-bold text-gray-900 mb-6 relative z-10">Application Form</h2>
        <form class="space-y-6 relative z-10" action="#" method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                <input type="text" id="firstName" name="firstName" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-gray-50 focus:bg-white" required>
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                <input type="text" id="lastName" name="lastName" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-gray-50 focus:bg-white" required>
              </div>
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-gray-50 focus:bg-white" required>
          </div>
          
          <div>
            <label for="interest" class="block text-sm font-medium text-gray-700 mb-1">Area of Interest / Skills</label>
            <input type="text" id="interest" name="interest" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-gray-50 focus:bg-white" placeholder="E.g., Agriculture, Teaching, Health..." required>
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Why do you want to volunteer with us?</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-gray-50 focus:bg-white resize-none" required></textarea>
          </div>
          
          <button type="submit" class="btn-primary w-full shadow-lg shadow-primary/30">
            Submit Application
          </button>
        </form>
      </div>

    </div>
  </section>
</Layout>
