---
import Layout from '../layouts/Layout.astro';
import FundraiseHero from '../components/fundraise/FundraiseHero.astro';
import WhyGive from '../components/fundraise/WhyGive.astro';
import ImpactAreas from '../components/fundraise/ImpactAreas.astro';
import DirectTransfer from '../components/fundraise/DirectTransfer.astro';
import GlobalGivingProjects from '../components/fundraise/GlobalGivingProjects.astro';
---

<Layout 
  title="Fundraise | MRC Nepal"
  description="Invest in rural resilience. Support MRC Nepal's high-impact initiatives in sustainable agriculture, clean water, and climate adaptation via direct transfer or GlobalGiving."
>
    <!-- Hero Section -->
    <FundraiseHero />

    <!-- Why Give to MRC Nepal -->
    <WhyGive />

    <!-- Impact Areas -->
    <ImpactAreas />

    <!-- Direct Bank Transfer Details -->
    <DirectTransfer />

    <!-- GlobalGiving Integration Section -->
    <section class="bg-gray-50 border-t border-gray-100">
        <div class="wrapper max-w-7xl mx-auto">
            <GlobalGivingProjects />
        </div>
    </section>
</Layout>
