---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import GlobalGivingProjects from '../components/GlobalGivingProjects.astro';

const localBankDetails = {
    accountName: "MRC Nepal",
    bankName: "Nepal Bank Limited",
    accountNumber: "xxxx-xxx-xxx-xxx",
    branch: "Kathmandu Main Branch"
};

const intlBankDetails = {
    accountName: "MRC Nepal",
    bankName: "Standard Chartered Bank Nepal",
    swiftCode: "SCBLNPKA",
    routingNo: "0104",
    accountNumber: "xxxx-xxx-xxx-xxx"
};
---

<Layout 
  title="Fundraise | MRC Nepal"
  description="Invest in rural resilience. Support MRC Nepal's high-impact initiatives in sustainable agriculture, clean water, and climate adaptation via direct transfer or GlobalGiving."
>
    <!-- Hero Section -->
    <section class="relative bg-green-900 text-white py-32 overflow-hidden pt-40">
        <!-- Background elements -->
        <div class="absolute inset-0 bg-primary/20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-black/60 via-black/20 to-transparent z-0"></div>
        <img 
            src="/assets/images/about/about_featured.webp" 
            alt="Community members working together" 
            class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-30 z-0"
        />

        <div class="wrapper relative z-10 text-center max-w-4xl mx-auto">
            <span class="inline-block py-1 px-4 rounded-full bg-secondary/90 text-white font-bold text-sm mb-6 uppercase tracking-widest shadow-lg">
                Support Our Mission
            </span>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 leading-tight drop-shadow-xl">
                Invest in <span class="text-secondary block mt-2">Rural Resilience</span>
            </h1>
            <p class="text-xl md:text-2xl text-white/95 leading-relaxed font-light mb-10 max-w-3xl mx-auto drop-shadow-md">
                Your partnership fuels community-led sustainable agriculture, critical environmental action, and comprehensive education across Nepal. Together, we create lasting generational change.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="#impact-areas" class="btn-primary py-4 px-8 text-lg font-bold shadow-xl shadow-primary/40 hover:-translate-y-1 transition-transform">
                    See Your Impact
                </a>
                <a href="#direct-transfer" class="btn-secondary bg-white text-green-900 border-white hover:bg-gray-100 py-4 px-8 text-lg font-bold hover:-translate-y-1 transition-transform shadow-xl">
                    Donate Now
                </a>
            </div>
        </div>
    </section>

    <!-- Why Give to MRC Nepal -->
    <section class="py-24 bg-white relative">
        <div class="wrapper max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <span class="text-secondary font-bold tracking-wider uppercase text-sm mb-2 block">Transparency & Trust</span>
                <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-6">Why Partner With MRC Nepal?</h2>
                <div class="w-24 h-1.5 bg-secondary mx-auto mb-6 rounded-full"></div>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
                    We believe in full financial transparency, sustainable community empowerment, and building self-reliance rather than continuous dependency. We hold ourselves highly accountable to both our donors and the communities we serve.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-gray-50 rounded-[2rem] p-10 border border-gray-100 text-center hover:shadow-xl hover:border-gray-200 hover:-translate-y-2 transition-all duration-300">
                    <div class="w-20 h-20 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-8 shadow-inner rotate-3 hover:rotate-6 transition-transform">
                        <Icon name="users" class="w-10 h-10" />
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Grassroots Direct Impact</h3>
                    <p class="text-gray-600 leading-relaxed">By maintaining incredibly low administrative overhead, your funds go directly into field operations, frontline training, and community-led initiatives where they matter most.</p>
                </div>
                
                <div class="bg-gray-50 rounded-[2rem] p-10 border border-gray-100 text-center hover:shadow-xl hover:border-gray-200 hover:-translate-y-2 transition-all duration-300">
                    <div class="w-20 h-20 bg-green-100 text-primary rounded-2xl flex items-center justify-center mx-auto mb-8 shadow-inner -rotate-3 hover:-rotate-6 transition-transform">
                        <Icon name="chart" class="w-10 h-10" />
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Sustainable Autonomy</h3>
                    <p class="text-gray-600 leading-relaxed">We don't just provide temporary relief. We focus on rigorous capacity-building regimens so that communities become fully equipped and permanently self-reliant.</p>
                </div>
                
                <div class="bg-gray-50 rounded-[2rem] p-10 border border-gray-100 text-center hover:shadow-xl hover:border-gray-200 hover:-translate-y-2 transition-all duration-300">
                    <div class="w-20 h-20 bg-secondary/20 text-secondary rounded-2xl flex items-center justify-center mx-auto mb-8 shadow-inner rotate-3 hover:rotate-6 transition-transform">
                        <Icon name="folder" class="w-10 h-10" />
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">35+ Years of Trust</h3>
                    <p class="text-gray-600 leading-relaxed">Since our inception, we have successfully orchestrated millions of dollars in grants, enjoying long-standing trust from global entities like USAID, UNDP, and OFID.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Areas -->
    <section id="impact-areas" class="py-24 bg-gray-50">
        <div class="wrapper max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <span class="text-primary font-bold tracking-wider uppercase text-sm mb-2 block">Direct Allocation</span>
                <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-6">Where Your Money Goes</h2>
                <div class="w-24 h-1.5 bg-primary mx-auto mb-6 rounded-full"></div>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">When you donate to our general fund, we allocate the capital across our three high-priority thematic action areas.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Impact Card 1 -->
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all">
                    <div class="h-48 bg-primary/10 relative overflow-hidden flex items-center justify-center">
                        <Icon name="briefcase" class="w-16 h-16 text-primary mix-blend-multiply opacity-50" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3">Sustainable Livelihoods</h3>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            Funding seeds, modern agricultural tools, livestock, and vital market-linkage training for marginalized farming families to elevate their income brackets.
                        </p>
                    </div>
                </div>

                <!-- Impact Card 2 -->
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all">
                    <div class="h-48 bg-blue-100 relative overflow-hidden flex items-center justify-center">
                        <Icon name="location" class="w-16 h-16 text-blue-600 mix-blend-multiply opacity-50" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3">WASH & Health</h3>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            Constructing desperately needed water catchment systems, community toilets, and organizing public health and sanitation camps in remote districts.
                        </p>
                    </div>
                </div>

                <!-- Impact Card 3 -->
                <div class="bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all">
                    <div class="h-48 bg-secondary/10 relative overflow-hidden flex items-center justify-center">
                         <Icon name="chart" class="w-16 h-16 text-secondary mix-blend-multiply opacity-50" />
                    </div>
                    <div class="p-8">
                        <h3 class="text-xl font-bold text-gray-900 mb-3">Climate Adaptation</h3>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">
                            Financing bio-gas plant installations, launching community reforestation drives, and implementing robust disaster risk reduction (DRR) strategies.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Direct Bank Transfer Details -->
    <section id="direct-transfer" class="py-24 bg-white">
        <div class="wrapper max-w-5xl mx-auto">
            <div class="bg-green-900 rounded-[2.5rem] p-8 md:p-14 text-white relative overflow-hidden shadow-2xl border border-green-800">
                <div class="absolute inset-0 bg-primary/30 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
                
                <!-- Decorative Circles -->
                <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary/40 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
                
                <div class="relative z-10">
                    <div class="text-center mb-12">
                        <div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center mx-auto mb-6 backdrop-blur-md border border-white/20 shadow-inner">
                            <Icon name="folder" class="w-10 h-10 text-secondary" />
                        </div>
                        <h2 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">Make a Direct Transfer</h2>
                        <p class="text-white/80 text-lg max-w-2xl mx-auto">
                            The most efficient way to support our mission is directly wiring your donation to our secured organizational treasury.
                        </p>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                        <!-- Local Transfers -->
                        <div class="bg-white/10 border border-white/20 p-8 rounded-3xl backdrop-blur-md hover:bg-white/15 transition-colors">
                            <h3 class="font-bold text-2xl mb-8 text-secondary flex items-center gap-3">
                                <span class="p-2 bg-secondary/20 rounded-lg"><Icon name="location" class="w-6 h-6" /></span> Local Remittance (NPR)
                            </h3>
                            <div class="space-y-6">
                                <div class="pb-4 border-b border-white/10">
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Account Name</p>
                                    <p class="font-bold text-xl tracking-wide">{localBankDetails.accountName}</p>
                                </div>
                                <div class="pb-4 border-b border-white/10">
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Bank Name</p>
                                    <p class="font-bold text-xl tracking-wide">{localBankDetails.bankName}</p>
                                </div>
                                <div class="pb-4 border-b border-white/10">
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Account Number</p>
                                    <p class="font-mono text-xl tracking-wide font-bold">{localBankDetails.accountNumber}</p>
                                </div>
                                <div>
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Branch</p>
                                    <p class="font-bold text-xl tracking-wide">{localBankDetails.branch}</p>
                                </div>
                            </div>
                        </div>

                        <!-- International Transfers -->
                        <div class="bg-white/10 border border-white/20 p-8 rounded-3xl backdrop-blur-md hover:bg-white/15 transition-colors relative">
                            <!-- Popular Tag -->
                            <div class="absolute -top-4 right-8 bg-secondary text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-lg">
                                International Donors
                            </div>

                            <h3 class="font-bold text-2xl mb-8 text-secondary flex items-center gap-3">
                                <span class="p-2 bg-secondary/20 rounded-lg"><Icon name="paper-plane" class="w-6 h-6" /></span> Wire Transfer (USD/EUR)
                            </h3>
                            <div class="space-y-6">
                                <div class="pb-4 border-b border-white/10">
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Account Name</p>
                                    <p class="font-bold text-xl tracking-wide">{intlBankDetails.accountName}</p>
                                </div>
                                <div class="pb-4 border-b border-white/10">
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Bank Name</p>
                                    <p class="font-bold text-xl tracking-wide">{intlBankDetails.bankName}</p>
                                </div>
                                <div class="flex gap-4 pb-4 border-b border-white/10">
                                    <div class="flex-1">
                                        <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">SWIFT Code</p>
                                        <p class="font-mono text-xl tracking-wide font-bold">{intlBankDetails.swiftCode}</p>
                                    </div>
                                    <div class="flex-1 border-l border-white/10 pl-4">
                                        <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Routing No.</p>
                                        <p class="font-mono text-xl tracking-wide font-bold">{intlBankDetails.routingNo}</p>
                                    </div>
                                </div>
                                <div>
                                    <p class="text-white/60 text-sm mb-1 uppercase tracking-wider font-semibold">Account Number</p>
                                    <p class="font-mono text-xl tracking-wide font-bold">{intlBankDetails.accountNumber}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-14 text-center bg-black/20 rounded-2xl p-6 backdrop-blur-sm border border-white/10">
                        <p class="text-white text-base">
                            <strong>Note:</strong> After making a transfer, please <a href="mailto:info@mrcnepal.org.np" class="text-secondary hover:text-white underline underline-offset-4 font-bold transition-colors">email us</a> with your transaction receipt so we can issue your official tax-deductible acknowledgment letter.
                        </p>
                    </div>
                </div>
            </div>
            
            <!-- Corporate Contact Banner -->
            <div class="mt-12 text-center">
                <p class="text-gray-600 text-lg">
                    Looking to establish a corporate CSR partnership, fund a specific village, or provide a major grant? <br/>
                    <a href="/contact" class="inline-flex items-center gap-2 text-primary font-bold hover:text-green-800 transition-colors mt-4 text-xl">
                        Contact our Leadership Team <Icon name="arrow-right" class="w-5 h-5" />
                    </a>
                </p>
            </div>
        </div>
    </section>

    <!-- GlobalGiving Integration Section -->
    <section class="bg-gray-50 border-t border-gray-100">
        <div class="wrapper max-w-7xl mx-auto">
            <GlobalGivingProjects />
        </div>
    </section>
</Layout>
