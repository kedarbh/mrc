---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, getEntry } from "astro:content";

const projectsEntries = await getCollection("projects");

// Sort projects by start date descending
projectsEntries.sort((a, b) => {
    const dateA = a.data.startDate?.getTime() || 0;
    const dateB = b.data.startDate?.getTime() || 0;
    return dateB - dateA;
});

const projects = await Promise.all(
  projectsEntries.map(async (project) => {
    let donorName = "Various / Self Funded";
    if (project.data.donor) {
      const donorEntry = await getEntry(project.data.donor);
      // Fallback to the ID if name not found in the partner markdown
      donorName = donorEntry?.data.name || project.data.donor.id;
    }
    
    // format period
    const startYear = project.data.startDate ? new Date(project.data.startDate).getFullYear() : "";
    let endYear = "Present";
    if (project.data.endDate) {
      endYear = new Date(project.data.endDate).getFullYear().toString();
    }
    const period = startYear ? `${startYear} - ${endYear}` : "Ongoing";

    return {
      name: project.data.title,
      district: project.data.location || "Multiple Setup",
      period: period,
      donor: donorName,
    };
  })
);
---

<Layout>
  <!-- Page Header -->
  <section class="relative bg-green-900 text-white py-32 overflow-hidden">
    <div class="absolute inset-0 bg-secondary/20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
    <div class="wrapper relative z-10 text-center max-w-4xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-secondary/20 text-secondary border border-secondary/30 font-medium text-sm mb-6 uppercase tracking-wider">
        Our Initiatives
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Our <span class="text-secondary">Projects</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed">
        A comprehensive overview of our past and ongoing initiatives driving sustainable development across Nepal.
      </p>
    </div>
  </section>

  <!-- Projects List -->
  <section class="section wrapper py-20 bg-gray-50/50">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full group">
          
          <div class="mb-4">
             <span class="inline-block py-1 px-3 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-wider mb-4 border border-primary/20">
                {project.period}
            </span>
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary transition-colors leading-tight">
              {project.name}
            </h3>
          </div>
          
          <div class="mt-auto space-y-3 pt-6 border-t border-gray-100">
            <div class="flex items-start gap-3">
              <div class="mt-0.5">
                  <Icon name="location" class="w-5 h-5 text-gray-400" />
              </div>
              <div>
                <p class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-0.5">Districts</p>
                <p class="text-gray-700 text-sm">{project.district}</p>
              </div>
            </div>
            
            <div class="flex items-start gap-3">
              <div class="mt-0.5">
                <!-- Using a generic piggy bank or volunteer icon as a placeholder for donor -->
                 <Icon name="piggy-bank" class="w-5 h-5 text-gray-400" />
              </div>
              <div>
                <p class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-0.5">Donor / Partner</p>
                <p class="text-gray-700 text-sm font-medium">{project.donor}</p>
              </div>
            </div>
          </div>
          
        </div>
      ))}
    </div>
  </section>
</Layout>
