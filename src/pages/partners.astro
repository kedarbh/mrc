---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const partners = await getCollection("partners");
---

<Layout>
  <!-- Hero Section -->
  <section class="relative bg-green-900 text-white py-32 overflow-hidden">
    <div class="absolute inset-0 bg-primary/20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-20"></div>
    <div class="wrapper relative z-10 text-center max-w-4xl mx-auto">
      <span class="inline-block py-1 px-3 rounded-full bg-secondary/20 text-secondary border border-secondary/30 font-medium text-sm mb-6 uppercase tracking-wider">
        Collaboration for Change
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Partnering for <span class="text-secondary">Global Impact</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed">
        Our work is made possible through the generous support and strategic collaboration of our international development partners. Together, we are building self-reliant societies in Nepal.
      </p>
    </div>
  </section>

  <!-- Value Proposition Section -->
  <section class="py-24 bg-gray-50 border-b border-gray-100">
    <div class="wrapper">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Why Partner With Us?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">MRC Nepal provides a trusted, effective, and grassroots-driven approach to sustainable development.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Prop 1 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary">
            <Icon name="location" class="w-8 h-8" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Grassroots Reach</h3>
          <p class="text-gray-600">Deeply embedded within rural communities, ensuring projects are culturally appropriate and effectively implemented where they are needed most.</p>
        </div>

        <!-- Prop 2 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-secondary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-secondary">
            <Icon name="phone" class="w-8 h-8" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Measurable Impact</h3>
          <p class="text-gray-600">Rigorous monitoring and evaluation frameworks guarantee transparency and measurable improvements in community livelihoods.</p>
        </div>

        <!-- Prop 3 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 text-center hover:shadow-lg transition-shadow duration-300">
          <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-6 text-blue-600">
            <Icon name="email" class="w-8 h-8" />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Proven Track Record</h3>
          <p class="text-gray-600">Over 35 years of successful program execution in sustainable agriculture, health, and organizational capacity building.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners Grid Section -->
  <section class="py-24 wrapper">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Donors & Partners</h2>
        <p class="text-lg text-gray-600">We are incredibly grateful to the organizations that fund and support our mission to empower rural communities.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {partners.map((partner) => (
        <div class="group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full">
          <!-- Logo Display Area -->
          <div class="bg-gray-50 h-48 p-8 flex items-center justify-center border-b border-gray-100 relative group-hover:bg-white transition-colors duration-300">
            {partner.data.logo ? (
              <Image 
                src={partner.data.logo} 
                alt={`${partner.data.name} Logo`} 
                class="max-w-full max-h-full object-contain filter grayscale group-hover:grayscale-0 transition-all duration-500 scale-95 group-hover:scale-100"
              />
            ) : (
                <div class="text-gray-400 font-medium">Logo Unavailable</div>
            )}
          </div>
          
          <!-- Content Area -->
          <div class="p-6 flex flex-col items-center justify-center gap-3">
            <!-- Title -->
            <h3 class="text-lg font-bold text-gray-900 text-center group-hover:text-primary transition-colors m-0">
                {partner.data.name}
            </h3>
            
            <!-- External Link -->
            {partner.data.website && (
                <a 
                  href={partner.data.website} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-secondary transition-colors"
                >
                    Visit Website &rarr;
                </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-green-950 text-white text-center">
    <div class="wrapper max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Become a Partner/ Donor</h2>
        <p class="text-lg text-white/80 mb-10 leading-relaxed">
            Are you an organization looking to make a measurable difference in rural Nepal? We are always looking to expand our network of strategic funders and collaborators.
        </p>
        <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-8 py-4 shadow-xl shadow-primary/20 hover:scale-105 transition-transform">
            Start a Conversation &rarr;
        </a>
    </div>
  </section>

</Layout>
